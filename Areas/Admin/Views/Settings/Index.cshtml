@{
    ViewData["Title"] = "Cài đặt | Admin Dashboard";
}

<div class="card" style="background:#111;border:1px solid var(--glass-border);padding:2rem;border-radius:12px;">
    <h2 class="brand-font" style="color: var(--accent-gold); margin-bottom: 1.5rem;">Cài Đặt Omni-channel</h2>
    <p style="color:#888;font-size:0.9rem;margin-bottom:1.5rem;">
        Quản lý kênh bán (Website, Shopee, Lazada, TikTok Shop) đồng bộ với frontend.
    </p>

    <table class="admin-table">
        <thead>
            <tr>
                <th>Kênh</th>
                <th>Logo</th>
                <th>Liên kết</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody id="channelsBody">
            <!-- load bằng JS từ /api/channels -->
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        async function loadChannels() {
            if (!window.user) return;
            const res = await fetch('/api/channels', {
                headers: { 'X-User-Role': window.user.role }
            });
            if (!res.ok) return;
            const data = await res.json();
            const tbody = document.getElementById('channelsBody');
            tbody.innerHTML = '';

            (data || []).forEach(ch => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><strong>${ch.channelName}</strong></td>
                    <td>
                        <img src="${ch.logoUrl || ''}" alt="${ch.channelName}" style="width:32px;height:32px;object-fit:contain;border-radius:4px;" 
                             onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(ch.channelName)}&background=222&color=c5a059&size=32';"/>
                    </td>
                    <td style="font-size:0.85rem;">
                        ${ch.linkUrl ? `<a href="${ch.linkUrl}" target="_blank" style="color:var(--accent-gold);text-decoration:none;">${ch.linkUrl}</a>` : '<span style="color:#555;">(chưa cấu hình)</span>'}
                    </td>
                    <td>
                        <span style="color:${ch.isActive ? '#27ae60' : '#e74c3c'};">
                            ${ch.isActive ? 'Đang bật' : 'Tắt'}
                        </span>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        loadChannels();
    </script>
}
